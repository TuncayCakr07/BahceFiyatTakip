@model BahceFiyatTakip.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Fiyatlar";

    string TimeAgo(DateTime? dt)
    {
        if (dt is null) return "";
        var diff = DateTime.Now - dt.Value.ToLocalTime();
        if (diff.TotalMinutes < 1) return "az önce";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} dk önce";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} sa önce";
        return $"{(int)diff.TotalDays} gün önce";
    }

    string ProductColor(string name) => name.ToLowerInvariant() switch
    {
        var n when n.Contains("mandalina")  => "#f97316",
        var n when n.Contains("portakal")   => "#fb923c",
        var n when n.Contains("limon otu")  => "#84cc16",
        var n when n.Contains("limon")      => "#eab308",
        var n when n.Contains("lime")       => "#22c55e",
        var n when n.Contains("avokado")    => "#16a34a",
        var n when n.Contains("nar")        => "#dc2626",
        var n when n.Contains("ejder")      => "#e11d48",
        var n when n.Contains("çarkıfelek") => "#a855f7",
        var n when n.Contains("mango")      => "#f59e0b",
        var n when n.Contains("domates")    => "#ef4444",
        var n when n.Contains("greyfurt")   => "#f472b6",
        var n when n.Contains("kumkuat")    => "#f97316",
        _                                   => "#64748b",
    };
}

@if (TempData["Message"] is string message)
{
    <div class="dash-alert">@message</div>
}

<div class="dash-header">
    <div>
        <h1 class="dash-title">Güncel Fiyatlar</h1>
        <p class="dash-sub">
            @Model.ProductSummaries.Count ürün
            &nbsp;·&nbsp;
            @Model.ProductSummaries.Sum(s => s.Prices.Count) market fiyatı
            &nbsp;·&nbsp;
            @Model.MarketCount aktif market
        </p>
    </div>
    <a asp-controller="PriceChecks" asp-action="Index" class="btn-goto">Fiyat Güncelle</a>
</div>

<div class="pcard-grid">
@foreach (var summary in Model.ProductSummaries)
{
    var best = summary.Cheapest!;
    var color = ProductColor(summary.Product.Name);

    <div class="pcard" style="--accent:@color">
        <div class="pcard-head">
            <div class="pcard-ident">
                <div class="pcard-dot"></div>
                <div>
                    <div class="pcard-name">@summary.Product.Name</div>
                    @if (summary.LastChecked.HasValue)
                    {
                        <div class="pcard-time">@TimeAgo(summary.LastChecked)</div>
                    }
                </div>
            </div>
            <form asp-controller="PriceChecks" asp-action="Check" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@summary.Product.Id" />
                <button type="submit" class="btn-upd" onclick="startLoading(this)">
                    <svg class="spin-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="display:none">
                        <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                    </svg>
                    <span class="upd-text">Güncelle</span>
                </button>
            </form>
        </div>

        <div class="pcard-best">
            <div class="best-left">
                @if (!string.IsNullOrWhiteSpace(best.ImageUrl))
                {
                    <img src="@best.ImageUrl" alt="" class="best-img" />
                }
                <div>
                    <div class="best-market">@best.Market.Name</div>
                    @if (!string.IsNullOrWhiteSpace(best.MatchedTitle))
                    {
                        <div class="best-title">@best.MatchedTitle</div>
                    }
                </div>
            </div>
            <div class="best-right">
                <div class="best-price">@best.PricePerKg.ToString("N2") <span>₺</span></div>
                <div class="best-unit">kg fiyatı</div>
            </div>
            @if (!string.IsNullOrWhiteSpace(best.SourceUrl))
            {
                <a href="@best.SourceUrl" target="_blank" class="best-link" title="Ürüne git">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                        <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                    </svg>
                </a>
            }
        </div>

        @if (summary.Prices.Count > 1)
        {
            <div class="price-rows">
                @foreach (var rec in summary.Prices.Skip(1))
                {
                    <div class="price-row">
                        <span class="pr-market">@rec.Market.Name</span>
                        <span class="pr-title">@(rec.MatchedTitle ?? "")</span>
                        <span class="pr-price">@rec.PricePerKg.ToString("N2") ₺</span>
                        @if (!string.IsNullOrWhiteSpace(rec.SourceUrl))
                        {
                            <a href="@rec.SourceUrl" target="_blank" class="pr-link">↗</a>
                        }
                    </div>
                }
            </div>
        }
    </div>
}
</div>

@section Scripts {
<script>
function startLoading(btn) {
    btn.disabled = true;
    btn.querySelector('.spin-icon').style.display = 'block';
    btn.querySelector('.upd-text').textContent = 'Yükleniyor…';
}
</script>
}
