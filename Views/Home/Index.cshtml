@model BahceFiyatTakip.ViewModels.HomeSummaryViewModel

@{
    ViewData["Title"]     = "Piyasa Özeti";
    ViewData["BodyClass"] = "home-body";

    string TimeAgo(DateTime? dt)
    {
        if (dt is null) return "—";
        var d = DateTime.Now - dt.Value.ToLocalTime();
        if (d.TotalMinutes < 1)  return "az önce";
        if (d.TotalMinutes < 60) return $"{(int)d.TotalMinutes} dk önce";
        if (d.TotalHours < 24)   return $"{(int)d.TotalHours} sa önce";
        if (d.TotalDays < 7)     return $"{(int)d.TotalDays} gün önce";
        return $"{(int)(d.TotalDays/7)} hafta önce";
    }

    string FreshClass(DateTime? dt)
    {
        if (!dt.HasValue) return "stale";
        var h = (DateTime.UtcNow - dt.Value).TotalHours;
        return h <= 24 ? "fresh" : h <= 168 ? "aging" : "stale";
    }

    string CategoryColor(string cat) => cat switch
    {
        "Narenciye" => "#f97316", "Tropikal" => "#16a34a",
        "Meyve"     => "#dc2626", "Sebze"    => "#65a30d",
        "İşlenmiş"  => "#d97706", "Diğer"    => "#9333ea",
        _           => "#94a3b8",
    };

    var categoryOrder = new Dictionary<string,int>
    {
        ["Narenciye"]=0,["Tropikal"]=1,["Meyve"]=2,["Sebze"]=3,["İşlenmiş"]=4,["Diğer"]=5
    };

    var byCategory = Model.Products
        .GroupBy(p => p.Category)
        .OrderBy(g => categoryOrder.GetValueOrDefault(g.Key, 99))
        .ToList();
}

@if (TempData["Message"] is string msg)
{
    <div class="dash-alert">@msg</div>
}

@* ═══ KPI ŞERİDİ ══════════════════════════════════════════════════════════ *@
<div class="kpi-strip">
    <div class="kpi-item">
        <div class="kpi-val">@Model.TotalProducts</div>
        <div class="kpi-lbl">Ürün</div>
    </div>
    <div class="kpi-div"></div>
    <div class="kpi-item">
        <div class="kpi-val">@Model.ProductsWithPrice</div>
        <div class="kpi-lbl">Fiyatlı Ürün</div>
    </div>
    <div class="kpi-div"></div>
    <div class="kpi-item">
        <div class="kpi-val">@Model.TotalMarkets</div>
        <div class="kpi-lbl">Market</div>
    </div>
    <div class="kpi-div kpi-div--push"></div>
    @if (Model.LastUpdate.HasValue)
    {
        <div class="kpi-item kpi-item--end">
            <div class="kpi-val kpi-val--sm">@TimeAgo(Model.LastUpdate)</div>
            <div class="kpi-lbl">Son Güncelleme</div>
        </div>
    }
</div>

@* ═══ ARAÇ ÇUBUĞU ═════════════════════════════════════════════════════════ *@
<div class="toolbar">
    <div class="search-wrap">
        <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input id="productSearch" type="search" class="search-input" placeholder="Ürün ara…" autocomplete="off" />
    </div>
    <div class="tb-gap"></div>
    <a asp-controller="PriceChecks" asp-action="Index" class="btn-all-update">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
        Fiyat Güncelle
    </a>
</div>

@* ═══ ÖZET KARTLARI ═══════════════════════════════════════════════════════ *@
@if (Model.Products.Count == 0)
{
    <p class="summary-empty">Henüz aktif ürün yok.</p>
}
else
{
    @foreach (var group in byCategory)
    {
        var catColor = CategoryColor(group.Key);
        <div class="category-band" style="--cat-color:@catColor">
            <div class="category-band-head">
                <span class="cat-band-bar"></span>
                <span class="cat-band-name">@group.Key</span>
                <span class="cat-band-count">@group.Count() ürün</span>
            </div>

            <div class="summary-grid">
                @foreach (var card in group)
                {
                    var freshCls = FreshClass(card.LastChecked);
                    <a asp-controller="Products" asp-action="Details" asp-route-id="@card.ProductId"
                       class="summary-card" data-name="@card.Name.ToLower()">
                        <div class="sc-top">
                            @if (!string.IsNullOrWhiteSpace(card.ImageUrl))
                            {
                                <img src="@card.ImageUrl" alt="" class="sc-img" loading="lazy" onerror="this.style.display='none'" />
                            }
                            else
                            {
                                <span class="sc-color-dot" style="background:@catColor"></span>
                            }
                            <div class="sc-title">
                                <div class="sc-name">@card.Name</div>
                                <div class="sc-sub">
                                    <span class="freshness-dot freshness-@freshCls"></span>
                                    @(card.HasAnyPrice ? TimeAgo(card.LastChecked) : "fiyat yok")
                                </div>
                            </div>
                        </div>

                        <div class="sc-bottom">
                            @if (card.HasAnyPrice)
                            {
                                <div class="sc-price">
                                    @card.BestPrice!.Value.ToString("N2")<span> ₺</span>
                                    <span class="sc-unit">/ @card.Unit.ToLower()</span>
                                </div>
                                <div class="sc-market">@card.BestMarketName</div>
                            }
                            else
                            {
                                <div class="sc-price sc-price--empty">—</div>
                            }
                            @if (card.TrendPct.HasValue)
                            {
                                <span class="trend-badge @(card.TrendPct < -2m ? "trend-drop" : card.TrendPct > 2m ? "trend-rise" : "trend-flat")">
                                    @(card.TrendPct < 0 ? "↓" : "↑")@Math.Abs(card.TrendPct.Value).ToString("N1")%
                                </span>
                            }
                        </div>
                    </a>
                }
            </div>
        </div>
    }
}

@section Scripts {
<script>
(function(){
    var si = document.getElementById('productSearch');
    if(!si) return;
    si.addEventListener('input', function(){
        var q = si.value.toLowerCase().trim();
        document.querySelectorAll('.summary-card').forEach(function(card){
            var name = card.dataset.name || '';
            card.style.display = !q || name.includes(q) ? '' : 'none';
        });
        document.querySelectorAll('.category-band').forEach(function(band){
            var anyVisible = Array.from(band.querySelectorAll('.summary-card')).some(function(c){ return c.style.display !== 'none'; });
            band.style.display = anyVisible ? '' : 'none';
        });
    });
})();
</script>
}
