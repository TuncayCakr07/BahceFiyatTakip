@{
    ViewData["Title"] = "Eksik URL Yönetimi";
}

@* Antiforgery token AJAX için *@
<form id="af-form" style="display:none">@Html.AntiForgeryToken()</form>

<div class="container-fluid py-3 px-4">

    <div class="d-flex align-items-center gap-3 mb-3">
        <h5 class="mb-0">Eksik URL Yönetimi</h5>
        <div id="um-summary" class="d-flex gap-2 flex-wrap"></div>
        <span class="ms-auto text-muted" style="font-size:.75rem" id="um-generated"></span>
    </div>

    <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
        <div class="btn-group btn-group-sm" role="group" id="um-filters">
            <button class="btn btn-primary um-filter-btn active" data-filter="all">Tümü</button>
            <button class="btn btn-outline-danger  um-filter-btn" data-filter="NoUrl">DirectUrl Yok</button>
            <button class="btn btn-outline-warning um-filter-btn" data-filter="UrlExistsNoPrice">URL Var Fiyat Yok</button>
            <button class="btn btn-outline-success um-filter-btn" data-filter="OkToday">Bugün Fiyat Geldi</button>
            <button class="btn btn-outline-secondary um-filter-btn" data-filter="OutOfStock" style="color:#d97706;border-color:#d97706">Stok Yok</button>
            <button class="btn btn-outline-secondary um-filter-btn" data-filter="MarketInactive">Pasif Market</button>
        </div>
        <input type="search" id="um-search" class="form-control form-control-sm ms-auto"
               placeholder="Ürün / çeşit / market ara…" style="max-width:220px">
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-bordered table-hover align-middle mb-0" id="um-table">
            <thead class="table-dark sticky-top">
                <tr>
                    <th>Ürün</th>
                    <th>Çeşit</th>
                    <th>Market</th>
                    <th style="width:130px">Durum</th>
                    <th>DirectUrl</th>
                    <th style="width:160px">Son Fiyat Tarihi</th>
                </tr>
            </thead>
            <tbody id="um-tbody">
                <tr><td colspan="6" class="text-center text-muted py-4">Yükleniyor…</td></tr>
            </tbody>
        </table>
    </div>

    <div class="text-muted mt-2" style="font-size:.75rem" id="um-rowcount"></div>
</div>

@* ── Aday URL Modal ── *@
<div class="modal fade" id="discoverModal" tabindex="-1" aria-labelledby="discoverModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header py-2">
        <div>
          <h6 class="modal-title mb-0" id="discoverModalLabel">Aday URL'ler</h6>
          <div class="text-muted" style="font-size:.7rem" id="discoverModalSub"></div>
        </div>
        <button type="button" class="btn-close ms-3" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0" id="discoverModalBody">
        <div class="text-center py-4 text-muted">Yükleniyor…</div>
      </div>
      <div class="modal-footer py-1">
        <span class="text-muted me-auto" style="font-size:.72rem">
          Market arama sayfasından çıkarılan adaylar. Google linki scraping içermez.
        </span>
        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Kapat</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
(function(){
    var allRows      = [];
    var activeFilter = 'all';
    var searchTerm   = '';
    var afToken      = (document.querySelector('#af-form input[name="__RequestVerificationToken"]') || {}).value || '';

    var STATUS = {
        OkToday:          { label:'Bugün OK',     cls:'text-bg-success',   btnOn:'btn-success',   btnOff:'btn-outline-success'   },
        UrlExistsNoPrice: { label:'Fiyat Yok',    cls:'text-bg-warning',   btnOn:'btn-warning',   btnOff:'btn-outline-warning'   },
        NoUrl:            { label:'URL Yok',       cls:'text-bg-danger',    btnOn:'btn-danger',    btnOff:'btn-outline-danger'    },
        OutOfStock:       { label:'Stok Yok',      cls:'text-bg-orange',    btnOn:'btn-orange',    btnOff:'btn-outline-orange'    },
        MarketInactive:   { label:'Pasif Market',  cls:'text-bg-secondary', btnOn:'btn-secondary', btnOff:'btn-outline-secondary' },
    };

    function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    function fmtDate(iso){
        if(!iso) return '—';
        var d = new Date(iso);
        return d.toLocaleDateString('tr-TR',{day:'2-digit',month:'2-digit',year:'numeric'})
             + ' ' + d.toLocaleTimeString('tr-TR',{hour:'2-digit',minute:'2-digit'});
    }

    function filtered(){
        return allRows.filter(function(r){
            if(activeFilter !== 'all' && r.status !== activeFilter) return false;
            if(searchTerm){
                var q = searchTerm.toLowerCase();
                return r.productName.toLowerCase().includes(q)
                    || r.varietyName.toLowerCase().includes(q)
                    || r.marketName.toLowerCase().includes(q)
                    || (r.directUrl||'').toLowerCase().includes(q);
            }
            return true;
        });
    }

    function render(){
        var rows = filtered();
        var tbody = document.getElementById('um-tbody');
        document.getElementById('um-rowcount').textContent = rows.length + ' satır gösteriliyor';
        if(!rows.length){
            tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">Kayıt yok</td></tr>';
            return;
        }
        tbody.innerHTML = rows.map(function(r){
            var sc  = STATUS[r.status] || {label:r.status, cls:'text-bg-secondary'};
            var urlVal = r.directUrl || '';
            var googleQuery = encodeURIComponent((r.productName+' '+r.varietyName+' '+(r.unit||'kg')).trim());
        var googleUrl = 'https://www.google.com/search?q='+googleQuery;
        var urlCell = '<div class="d-flex gap-1 align-items-center flex-wrap url-cell">'
                + '<input type="url" class="form-control form-control-sm url-input flex-grow-1"'
                + ' value="'+esc(urlVal)+'"'
                + ' data-variety="'+r.varietyId+'" data-market="'+r.marketId+'"'
                + ' style="font-size:.78em;min-width:180px" placeholder="https://…">'
                + '<button class="btn btn-sm btn-outline-primary url-save-btn flex-shrink-0"'
                + ' data-variety="'+r.varietyId+'" data-market="'+r.marketId+'">Kaydet</button>'
                + '<span class="url-feedback" style="font-size:.75em;min-width:70px;white-space:nowrap"></span>'
                + '<button class="btn btn-sm btn-outline-info url-test-btn flex-shrink-0"'
                + ' data-variety="'+r.varietyId+'" data-market="'+r.marketId+'">Test Et</button>'
                + '<span class="url-test-result" style="font-size:.72em;white-space:nowrap"></span>'
                + '<a class="btn btn-sm btn-outline-secondary flex-shrink-0" href="'+googleUrl+'" target="_blank" rel="noopener" title="Google\'da ara: '+esc(decodeURIComponent(googleQuery))+'">🔍 Google</a>'
                + (r.status === 'NoUrl'
                    ? '<button class="btn btn-sm btn-outline-info discover-btn flex-shrink-0"'
                      + ' data-variety="'+r.varietyId+'"'
                      + ' data-market="'+r.marketId+'"'
                      + ' data-product-id="'+(r.productId||0)+'"'
                      + ' data-product="'+esc(r.productName)+'"'
                      + ' data-vname="'+esc(r.varietyName)+'"'
                      + ' data-unit="'+esc(r.unit||'kg')+'"'
                      + ' data-mname="'+esc(r.marketName)+'">🔎 Aday Bul</button>'
                    : '')
                + '</div>';
            var lastDate = fmtDate(r.lastPriceAt);
            var lastPriceStr = r.lastPrice ? ' <span class="text-muted">· '+r.lastPrice.toFixed(2)+' ₺</span>' : '';
            return '<tr>'
                +'<td>'+esc(r.productName)+'</td>'
                +'<td><span class="text-muted" style="font-size:.82em">'+esc(r.varietyName)+'</span></td>'
                +'<td>'+esc(r.marketName)+'</td>'
                +'<td><span class="badge '+sc.cls+'" style="font-size:.75em">'+sc.label+'</span></td>'
                +'<td style="font-size:.8em">'+urlCell+'</td>'
                +'<td style="font-size:.8em;white-space:nowrap">'+lastDate+lastPriceStr+'</td>'
                +'</tr>';
        }).join('');
    }

    // Buton tıklama — event delegation (Kaydet + Test Et)
    document.getElementById('um-tbody').addEventListener('click', function(e){
        var saveBtn = e.target.closest('.url-save-btn');
        if(saveBtn){
            var vid = parseInt(saveBtn.dataset.variety);
            var mid = parseInt(saveBtn.dataset.market);
            var input = saveBtn.closest('.url-cell').querySelector('.url-input');
            var feedback = saveBtn.nextElementSibling;
            saveUrl(vid, mid, input ? input.value.trim() : '', saveBtn, feedback);
            return;
        }
        var testBtn = e.target.closest('.url-test-btn');
        if(testBtn){
            var input2 = testBtn.closest('.url-cell').querySelector('.url-input');
            var result = testBtn.nextElementSibling;
            testUrl(input2 ? input2.value.trim() : '', testBtn, result);
            return;
        }
        var discBtn = e.target.closest('.discover-btn');
        if(discBtn){
            discoverCandidates(
                parseInt(discBtn.dataset.variety),
                parseInt(discBtn.dataset.market),
                parseInt(discBtn.dataset.productId||'0'),
                discBtn.dataset.product,
                discBtn.dataset.vname,
                discBtn.dataset.unit,
                discBtn.dataset.mname
            );
        }
    });

    // Enter tuşu ile kaydet
    document.getElementById('um-tbody').addEventListener('keydown', function(e){
        if(e.key !== 'Enter') return;
        var input = e.target.closest('.url-input');
        if(!input) return;
        var saveBtn = input.parentElement.querySelector('.url-save-btn');
        if(saveBtn) saveBtn.click();
    });

    async function testUrl(url, btn, result){
        if(!url){ result.textContent='✗ URL boş'; result.style.color='#dc2626'; return; }
        btn.disabled=true; btn.textContent='…'; result.textContent='';
        try{
            var resp = await fetch('/Home/TestDirectUrl',{
                method:'POST',
                headers:{'Content-Type':'application/json','RequestVerificationToken':afToken},
                body:JSON.stringify({url:url})
            });
            var d = await resp.json();
            if(d.success){
                result.innerHTML='✓ '+esc(d.title)+' — <b>'+d.price.toFixed(2)+' ₺</b>';
                result.style.color='#16a34a';
            } else {
                result.textContent='✗ '+(d.error||'Fiyat bulunamadı');
                result.style.color='#dc2626';
            }
        } catch(ex){
            result.textContent='✗ Bağlantı hatası';
            result.style.color='#dc2626';
        }
        btn.disabled=false; btn.textContent='Test Et';
    }

    async function saveUrl(varietyId, marketId, directUrl, btn, feedback){
        btn.disabled = true;
        btn.textContent = '…';
        feedback.textContent = '';
        try{
            var resp = await fetch('/Home/SaveDirectUrl', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': afToken
                },
                body: JSON.stringify({ varietyId: varietyId, marketId: marketId, directUrl: directUrl })
            });
            if(resp.ok){
                feedback.textContent = '✓ Kaydedildi';
                feedback.style.color = '#16a34a';
                // Cache güncelle
                var row = allRows.find(function(r){ return r.varietyId===varietyId && r.marketId===marketId; });
                if(row) row.directUrl = directUrl || null;
                setTimeout(function(){ feedback.textContent=''; }, 3000);
            } else {
                var err = await resp.json().catch(function(){ return {}; });
                feedback.textContent = '✗ ' + (err.error||'Hata');
                feedback.style.color = '#dc2626';
                setTimeout(function(){ feedback.textContent=''; }, 4000);
            }
        } catch(ex){
            feedback.textContent = '✗ Bağlantı hatası';
            feedback.style.color = '#dc2626';
            setTimeout(function(){ feedback.textContent=''; }, 4000);
        }
        btn.disabled  = false;
        btn.textContent = 'Kaydet';
    }

    function renderSummary(data){
        document.getElementById('um-summary').innerHTML =
            '<span class="badge text-bg-primary">'+data.rows.length+' toplam</span>'
           +'<span class="badge text-bg-success">'+data.okTodayCount+' bugün ok</span>'
           +'<span class="badge text-bg-warning text-dark">'+data.urlNoPriceCount+' fiyat yok</span>'
           +'<span class="badge text-bg-danger">'+data.noUrlCount+' url yok</span>'
           +(data.outOfStockCount > 0 ? '<span class="badge" style="background:#fef3c7;color:#92400e">'+data.outOfStockCount+' stok yok</span>' : '')
           +'<span class="badge text-bg-secondary">'+data.inactiveCount+' pasif</span>';
        var g = document.getElementById('um-generated');
        if(g) g.textContent = 'Oluşturuldu: '+fmtDate(data.generatedAt);
    }

    // Filter butonları
    document.getElementById('um-filters').addEventListener('click', function(e){
        var btn = e.target.closest('.um-filter-btn');
        if(!btn) return;
        activeFilter = btn.dataset.filter;
        document.querySelectorAll('.um-filter-btn').forEach(function(b){
            var st = STATUS[b.dataset.filter];
            if(b.dataset.filter==='all'){
                b.className = 'btn btn-sm um-filter-btn'+(b===btn?' btn-primary active':' btn-outline-primary');
            } else {
                b.className = 'btn btn-sm um-filter-btn'+(b===btn?' '+(st?st.btnOn:'btn-primary')+' active':' '+(st?st.btnOff:'btn-outline-primary'));
            }
        });
        render();
    });

    // Arama
    document.getElementById('um-search').addEventListener('input', function(){
        searchTerm = this.value.trim();
        render();
    });

    // Veri çek
    fetch('/Home/UrlReport')
        .then(function(r){ return r.json(); })
        .then(function(data){
            allRows = data.rows;
            renderSummary(data);
            render();
        })
        .catch(function(){
            document.getElementById('um-tbody').innerHTML =
                '<tr><td colspan="6" class="text-center text-danger py-3">Veri yüklenemedi.</td></tr>';
        });

    // ── URL Aday Keşif ───────────────────────────────────────────────────────
    var discoverCtx = null; // {varietyId, marketId}

    async function discoverCandidates(varietyId, marketId, productId, productName, varietyName, unit, marketName){
        discoverCtx = { varietyId: varietyId, marketId: marketId };
        var modalEl   = document.getElementById('discoverModal');
        var bsModal   = new bootstrap.Modal(modalEl);
        document.getElementById('discoverModalLabel').textContent =
            'Aday URL — '+productName+' '+varietyName+' / '+marketName;
        document.getElementById('discoverModalSub').textContent =
            'DirectUrl boş olan bu satır için market arama sayfasından URL adayları aranıyor…';
        document.getElementById('discoverModalBody').innerHTML =
            '<div class="text-center py-4"><span class="spinner-border spinner-border-sm me-2"></span>Aranıyor… (max 20 sn)</div>';
        bsModal.show();

        try {
            var resp = await fetch('/Home/DiscoverDirectUrlCandidates', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': afToken
                },
                body: JSON.stringify({
                    productId: productId,
                    varietyId: varietyId,
                    marketId: marketId,
                    productName: productName,
                    varietyName: varietyName,
                    unit: unit,
                    marketName: marketName
                })
            });
            if(!resp.ok) throw new Error('HTTP '+resp.status);
            var candidates = await resp.json();
            renderCandidates(candidates, productName, varietyName);
        } catch(ex) {
            document.getElementById('discoverModalBody').innerHTML =
                '<div class="text-danger p-3">Hata: '+esc(String(ex.message||ex))+'</div>';
        }
    }

    function renderCandidates(candidates, productName, varietyName){
        document.getElementById('discoverModalSub').textContent =
            candidates.length + ' aday bulundu • Kullanmak istediğiniz URL için "Kullan" butonuna basın.';

        if(!candidates.length){
            document.getElementById('discoverModalBody').innerHTML =
                '<div class="text-muted p-3 text-center">Aday bulunamadı.</div>';
            return;
        }

        var html = '<div class="list-group list-group-flush">';
        candidates.forEach(function(c, idx){
            var isGoogle = c.source === 'Google';
            var scoreCls = c.score >= 70 ? 'text-bg-success' :
                           c.score >= 40 ? 'text-bg-warning text-dark' :
                           c.score > 0  ? 'text-bg-secondary' : 'text-bg-light text-dark';
            var shortUrl = c.url.length > 75 ? c.url.slice(0,72)+'…' : c.url;

            html += '<div class="list-group-item py-2 px-3 border-start-0 border-end-0">';
            html += '<div class="d-flex align-items-start gap-2">';
            html += '<div class="flex-grow-1" style="min-width:0;overflow:hidden">';
            html += '<div class="fw-semibold" style="font-size:.85rem;word-break:break-word">'+esc(c.title)+'</div>';
            if(isGoogle){
                html += '<a href="'+esc(c.url)+'" target="_blank" rel="noopener noreferrer"'
                      + ' style="font-size:.72rem;color:#64748b;word-break:break-all">'+esc(shortUrl)+'</a>';
            } else {
                html += '<div style="font-size:.72rem;color:#64748b;word-break:break-all">'+esc(shortUrl)+'</div>';
            }
            html += '<div style="font-size:.69rem;color:#94a3b8;margin-top:1px">'+esc(c.reason)+'</div>';
            html += '</div>';
            html += '<div class="d-flex flex-column align-items-end gap-1 flex-shrink-0">';
            html += '<span class="badge '+scoreCls+'" style="font-size:.68em">'+c.score+' puan</span>';
            if(!isGoogle){
                html += '<div class="d-flex gap-1 mt-1">';
                html += '<button class="btn btn-xs btn-outline-info cand-test-btn py-0 px-2" style="font-size:.75rem"'
                      + ' data-url="'+esc(c.url)+'" data-idx="'+idx+'">Test Et</button>';
                html += '<button class="btn btn-xs btn-success cand-use-btn py-0 px-2" style="font-size:.75rem"'
                      + ' data-url="'+esc(c.url)+'">Kullan</button>';
                html += '</div>';
                html += '<span id="cand-result-'+idx+'" class="cand-result-span" style="font-size:.69rem;text-align:right;max-width:160px;word-break:break-word"></span>';
            }
            html += '</div>';
            html += '</div>';
            html += '</div>';
        });
        html += '</div>';
        document.getElementById('discoverModalBody').innerHTML = html;
    }

    // Modal içi buton tıklamaları
    document.getElementById('discoverModal').addEventListener('click', function(e){
        var testBtn = e.target.closest('.cand-test-btn');
        if(testBtn){
            var url3 = testBtn.dataset.url;
            var idx3 = testBtn.dataset.idx;
            var resEl = document.getElementById('cand-result-'+idx3);
            testUrl(url3, testBtn, resEl);
            return;
        }
        var useBtn = e.target.closest('.cand-use-btn');
        if(useBtn && discoverCtx){
            var vid2 = discoverCtx.varietyId;
            var mid2 = discoverCtx.marketId;
            var url4 = useBtn.dataset.url;
            // URL inputunu güncelle
            var rowInput = document.querySelector('.url-input[data-variety="'+vid2+'"][data-market="'+mid2+'"]');
            if(rowInput) rowInput.value = url4;
            // Modali kapat
            bootstrap.Modal.getInstance(document.getElementById('discoverModal')).hide();
            // Kaydet
            var saveBtnEl = document.querySelector('.url-save-btn[data-variety="'+vid2+'"][data-market="'+mid2+'"]');
            var fbEl      = saveBtnEl ? saveBtnEl.nextElementSibling : null;
            if(saveBtnEl && fbEl) saveUrl(vid2, mid2, url4, saveBtnEl, fbEl);
        }
    });
})();
</script>
}
