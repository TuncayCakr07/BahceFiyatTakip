@{
    ViewData["Title"] = "Fiyat Kontrol";
}

<div class="check-page-card">
    <h1>Canlı Fiyat Çek</h1>
    <p style="color:var(--gray-600);margin-bottom:1.5rem;font-size:.9rem;">
        Seçilen ürün için tüm aktif marketler paralel olarak taranır.<br>
        Playwright ile JavaScript gerektiren siteler de dahil edilir.
    </p>

    <form asp-action="Check" method="post" id="checkForm">
        <div class="mb-3">
            <label class="form-label fw-semibold">Ürün</label>
            <select name="productId" class="form-select" asp-items="ViewBag.Products" required>
                <option value="">— Ürün seçin —</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" id="submitBtn">
            <span id="btnText">Canlı Fiyatları Çek</span>
            <span id="btnSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status"></span>
        </button>
    </form>
</div>

@section Scripts {
<script>
document.getElementById('checkForm').addEventListener('submit', function() {
    var btn = document.getElementById('submitBtn');
    btn.disabled = true;
    document.getElementById('btnText').textContent = 'Taranıyor…';
    document.getElementById('btnSpinner').classList.remove('d-none');
});
</script>
}
