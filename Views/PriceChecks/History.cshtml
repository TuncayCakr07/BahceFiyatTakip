@model BahceFiyatTakip.ViewModels.PriceHistoryViewModel

@{
    ViewData["Title"] = "Fiyat Geçmişi";
}

@if (TempData["Message"] is string message)
{
    <div class="alert alert-success mb-4">@message</div>
}

<div class="panel-section mb-4">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label fw-semibold" style="font-size:.82rem;color:var(--gray-600)">ÜRÜN</label>
            <select name="productId" class="form-select form-select-sm">
                <option value="">Tümü</option>
                @foreach (var product in Model.Products)
                {
                    <option value="@product.Id" selected="@(Model.ProductId == product.Id)">@product.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-semibold" style="font-size:.82rem;color:var(--gray-600)">MARKET</label>
            <select name="marketId" class="form-select form-select-sm">
                <option value="">Tümü</option>
                @foreach (var market in Model.Markets)
                {
                    <option value="@market.Id" selected="@(Model.MarketId == market.Id)">@market.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold" style="font-size:.82rem;color:var(--gray-600)">BAŞLANGIÇ</label>
            <input type="date" name="startDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <label class="form-label fw-semibold" style="font-size:.82rem;color:var(--gray-600)">BİTİŞ</label>
            <input type="date" name="endDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary btn-sm w-100">Filtrele</button>
        </div>
    </form>
</div>

<div class="panel-section">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Ürün</th>
                    <th>Çeşit / Eşleşen</th>
                    <th>Market</th>
                    <th>Resim</th>
                    <th class="text-end">Fiyat</th>
                    <th>Tarih</th>
                    <th>Kaynak</th>
                    <th class="text-center">Güven</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Records.Any())
            {
                @foreach (var item in Model.Records)
                {
                    <tr>
                        <td class="fw-semibold">@item.Product.Name</td>
                        <td>
                            <div style="font-size:.85rem;font-weight:600">@(item.ProductVariety?.Name ?? "—")</div>
                            @if (!string.IsNullOrWhiteSpace(item.MatchedTitle))
                            {
                                <div style="font-size:.75rem;color:var(--gray-400)">@item.MatchedTitle</div>
                            }
                        </td>
                        <td style="font-size:.9rem">@item.Market.Name</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <a href="@item.SourceUrl" target="_blank">
                                    <img src="@item.ImageUrl" alt="@item.MatchedTitle" class="product-thumb" />
                                </a>
                            }
                        </td>
                        <td class="text-end fw-bold" style="font-size:1rem;color:var(--green)">
                            @item.PricePerKg.ToString("N2") ₺
                            <div style="font-size:.7rem;color:var(--gray-400);font-weight:400">/kg</div>
                        </td>
                        <td style="font-size:.8rem;color:var(--gray-600)">@item.CheckedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            <span class="@(item.IsLive ? "badge-live" : "badge-mock")">
                                @(item.IsLive ? "Canlı" : "Mock")
                            </span>
                        </td>
                        <td class="text-center" style="font-size:.85rem;color:var(--gray-600)">@item.ConfidenceScore</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center py-4" style="color:var(--gray-400)">
                        Seçili filtreler için kayıt bulunamadı.
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
