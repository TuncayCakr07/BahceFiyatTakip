<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bahçe Fiyat Takip</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="site-nav">
        <a class="brand" asp-controller="Home" asp-action="Index">Bahçe Fiyat</a>
        <ul class="nav-links">
            <li><a asp-controller="Home" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">Panel</a></li>
            <li><a asp-controller="PriceChecks" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "PriceChecks" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">Fiyat Kontrol</a></li>
            <li><a asp-controller="PriceChecks" asp-action="History"
                   class="@(ViewContext.RouteData.Values["action"]?.ToString() == "History" ? "active" : "")">Geçmiş</a></li>
            <li><a asp-controller="Products" asp-action="Index"
                   class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")">Ürünler</a></li>
        </ul>
    </nav>

    <div class="page-wrapper">
        <main>
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        &copy; 2026 Bahçe Fiyat Takip
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
