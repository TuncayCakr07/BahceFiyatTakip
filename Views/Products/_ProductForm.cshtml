@model BahceFiyatTakip.Models.Product

<div class="panel-section">
    <form asp-action="@ViewContext.RouteData.Values["action"]" method="post" class="row g-3">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" placeholder="Portakal" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Category" class="form-label"></label>
            <input asp-for="Category" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Unit" class="form-label"></label>
            <input asp-for="Unit" class="form-control" />
        </div>
        <div class="col-12">
            <label asp-for="ImageUrl" class="form-label">Varsayılan Resim URL'si</label>
            <div class="d-flex gap-2 align-items-start">
                <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                @if (!string.IsNullOrWhiteSpace(Model?.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="önizleme"
                         style="width:48px;height:48px;object-fit:contain;border-radius:6px;border:1px solid #e5e7eb;background:#f9fafb;flex-shrink:0"
                         onerror="this.style.display='none'" />
                }
            </div>
            <div class="form-text">Scraper resim bulamazsa bu URL gösterilir. Market ürün resmi veya Wikimedia fotoğrafı olabilir.</div>
        </div>
        <div class="col-12">
            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-success">Kaydet</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Vazgec</a>
        </div>
    </form>
</div>
